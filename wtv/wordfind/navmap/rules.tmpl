<title>WebTV WordFinder</title>

<SCRIPT Language="JavaScript">
	
	function getURLvar(Name) {{
		var search = Name + "="
		var incoming = window.location.search
		if (incoming.length > 0) {{ // if there are any search parameters
			offset = incoming.indexOf(search) 
			if (offset != -1) {{ // if parameter exists 
				offset += search.length 
				// set index of beginning of value
				end = incoming.indexOf("&", offset) 
				// set index of end of cookie value
				if (end == -1) 
					end = incoming.length
				value = unescape(incoming.substring(offset, end))
				if (value == "") {{
					return null
				} else {{
					return value
				}
			}
			else return null
		}
		else return null
	}

	function PassQueryToPage(pageName) {{
		var chosengame = getURLvar("game")
		var mysearch = window.location.search
//	alert (mysearch)
		var modifier = "N"
		if (mysearch != "") {{
			modifier= "&"
			if (mysearch.charAt(0) != "?")
				mysearch = "?"+ mysearch;    
		}
		else
		{{
			modifier = "?"
			mysearch = ""
		} 
		var bigwoofie = pageName +  mysearch  + modifier 
		bigwoofie = bigwoofie + "game=" + chosengame +"&"
		
		bigwoofie = bigwoofie +"the=end" 
		window.location = bigwoofie
	}

function Redirect(sURL) {{
  window.location=sURL;
} 
function RedirectToGame() {{
 	sURL=getURLvar("game")
	gameURL = "../" + sURL;
	
  window.location= gameURL;
} 

	</SCRIPT>


