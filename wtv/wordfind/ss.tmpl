	function UpdateTimeLeft() {{ 
          document.tenstime.src="images/"+GetDigit(iSecondsLeft,0)+".gif";
          document.onestime.src="images/"+GetDigit(iSecondsLeft,1)+".gif";
          document.minutes.src="images/"+iMinutesLeft+".gif";
        }

        function RenderCell(x, y) {{ 

	  letter = GetCell(x,y);

	  document.write("<td abswidth=20 width=20 absheight=20 height=20 bgcolor=666666 align=center valign=bottom>");
	  document.write("  <a selected href=\"javascript:SelectEndpoint("+x+","+y+")\"><img src=images/"+letter+"OFF.JPG></a>");
	  document.write("</td>");

	}

	    function RenderRow(y) {{

	  document.write("<tr>");

	  for (x=0; x < kWidth; x++) {{
	     RenderCell(x,y);
	  }

	  document.write("</tr>");

	}

	function RenderPuzzle() {{
	 
	  document.write("<table border=0 cellspacing=3 cellpadding=0 bgcolor=222222>");

	  for (y=0; y < kHeight; y++) {{
	     RenderRow(y);
	  }

 	       document.write("</table>");

	     }

		function Restart() {{

		  location.reload();

		}

		function Quit() {{

		  alert("Quit");

		}

		function SolvePuzzle() {{

		  for (i=0; i < iTotalWords; i++) {{
		  
		     var startx = eval(aStartX[i]);
		     var starty = eval(aStartY[i]);
		     var stopx  = eval(aStopX[i]);
		     var stopy  = eval(aStopY[i]);      
		  
		     abWordFound[i] = "true";
		     HighlightSelection(startx,starty,stopx,stopy);
		     
		  }

		  sGameState = "solved";
		  iWordsLeft = 0;
		  UpdateWordsLeft();

		}

		function Highlight1LengthWords() {{

		  for (i=0; i < iTotalWords; i++) {{
		     var startx = eval(aStartX[i]);
			 if (aLength[i] == 1) {{
               HighlightSelection(aStartX[i], aStartY[i], aStopX[i], aStopY[i]);
               abWordFound[i] = "true";
             }
          }

		}

		function ShowHint() {{

		  // Find Answer to Hint

		  if (sGameState != "inplay")
		    return;

		  for (iHintAnswer=0; 
		       (abWordFound[eval(iHintAnswer)] != "false") && 
		       (iHintAnswer < iTotalWords); 
		       iHintAnswer++) {{ }

		  if (iHintAnswer == iTotalWords)
		    return;

		  // Find Letter to Hint

		  iHintLetter = Math.round(Math.random()*(
					     eval(aLength[eval(iHintAnswer)])-1
							 )
					  );
				     
		  // Invert Letter

		
		  PlaySound(document.swoosh);
		  sHintOld = HintLetter(aStartX[iHintAnswer], aStartY[iHintAnswer], 
			     aStopX[iHintAnswer], aStopY[iHintAnswer], iHintLetter, "true", "");

		  // Set Timer to Reinvert.
	  
		  sCommand = "HintLetter("+aStartX[iHintAnswer]+","+aStartY[iHintAnswer]+","+aStopX[iHintAnswer]+","+aStopY[iHintAnswer]+","+iHintLetter+",\"false\",\""+sHintOld+"\")";
	  window.setTimeout(sCommand, kHintLength);

		  DecrementTimeLeft(5);
		  UpdateTimeLeft();
		 
	
		}

