		  sLetterLookup = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";

	function RandomLetter() {{

	   iLetterASCII = Math.round(Math.random()*25);
		   return(sLetterLookup.charAt(iLetterASCII));

		}

	function BuildPuzzle() {{

	  puzzle = new Array(kHeight);

	  for (y=0; y < kHeight; y++) {{
	     puzzle[y] = "";
			 for (x=0; x < kWidth; x++) {{
		if (GetInCell(x,y) == "+") {{
		  puzzle[y] = puzzle[y] + RandomLetter();
				} else {{
				  puzzle[y] = puzzle[y] + GetInCell(x,y);
				}
			    
			 }
		  }

	}

	function CheckSelection(iStartX, iStartY, iStopX, iStopY) {{

	   for (i=0; i < iTotalWords; i++) {{
	      if (eval(iStartX) == eval(aStartX[i]) &&
				  eval(iStartY) == eval(aStartY[i]) &&
				  eval(iStopX) == eval(aStopX[i]) &&
				  eval(iStopY) == eval(aStopY[i]) ||
		      eval(iStopX) == eval(aStartX[i]) &&
				  eval(iStopY) == eval(aStartY[i]) &&
				  eval(iStartX) == eval(aStopX[i]) &&
				  eval(iStartY) == eval(aStopY[i])) {{

				return (i);
			  }
	
		   }

		   return (-1);

		}

                function ComputeSlope(fDiff) {{
                 
                  var fSlope;

                  if (fDiff == 0) {{
                    fSlope = 0;
                  } else {{
                    if (fDiff < 0) {{
                      fSlope = -1;
                    } else {{
                     fSlope = 1;
                    }
                  }   

                  return(fSlope); 

                }

		function HintLetter(iStartX, iStartY, iStopX, iStopY, iLetter, bSelected, sSaveImg) {{
	  var fxDiff = eval(eval(iStopX) - eval(iStartX));
	var 	  fyDiff = eval(eval(iStopY) - eval(iStartY));

         var fySlope = ComputeSlope(fyDiff);
         var fxSlope = ComputeSlope(fxDiff);

		  var iCurrX = eval(eval(iStartX)+eval(iLetter)*eval(fxSlope));  
		  var iCurrY = eval(eval(iStartY)+eval(iLetter)*eval(fySlope));  

		  if (bSelected == "true") {{
            var sSaveImg = document.images[eval(iCurrX)+eval(iCurrY*kWidth)+eval(kOtherFormElements)].src;
		    document.images[eval(iCurrX)+eval(iCurrY*kWidth)+eval(kOtherFormElements)].src = "images/"+GetCell(iCurrX, iCurrY)+"ON.JPG";
			return (sSaveImg);
	      } else {{
		    document.images[eval(iCurrX)+eval(iCurrY*kWidth)+eval(kOtherFormElements)].src = sSaveImg;
		  }

		}

	function HighlightSelection(iStartX, iStartY, iStopX, iStopY) {{

	  var fxDiff = eval(iStopX - iStartX);
 	  var fyDiff = eval(iStopY - iStartY);

          var fxSlope = ComputeSlope(fxDiff);
          var fySlope = ComputeSlope(fyDiff);

	  iCurrX = iStartX;  iCurrY = iStartY;

	  while ( (iCurrX != iStopX) || (iCurrY != iStopY) ) {{
	  
		   alert("first"+GetCell(iCurrX, iCurrY)+"ON.JPG");
		    document.images[eval(iCurrX)+eval(iCurrY*kWidth)+eval(kOtherFormElements)].src = "images/"+GetCell(iCurrX, iCurrY)+"ON.JPG";
	    
		    iCurrX = eval(eval(iCurrX) + eval(fxSlope));
			iCurrY = eval(eval(iCurrY) + eval(fySlope));
				      
	  }

		  alert("2nd"+GetCell(iCurrX, iCurrY)+"ON.JPG");
	      document.images[eval(iCurrX)+eval(iCurrY*kWidth)+eval(kOtherFormElements)].src = "images/"+GetCell(iCurrX, iCurrY)+"ON.JPG";
	    
		}

        function PlaySound(sound) {{

          if (sound == null) {{  
            return;
          } else {{
            sound.play(false);
          }

        }
	    function SelectEndpoint(x,y) {{

		  if (sGameState != "inplay")
		    return;

		  if (iPointsSelected == 0) {{
	    iStartX = x; iStartY = y;
		    iPointsSelected = 1;
			DisplayStatus(iPointsSelected);
			sSelectEndOld = HintLetter(x, y, x, y, 0, "true", "");
			return;
		  }

	  iStopX = x; iStopY = y;
	  if (iStopX == iStartX && iStopY == iStartY) {{
            iPointsSelected = 0;
	    DisplayStatus(iPointsSelected);
            HintLetter(iStopX, iStopY, iStopX, iStopY, 0, "false", sSelectEndOld);
            return;
          }

	  iWordSelected = CheckSelection(iStartX, iStartY, iStopX, iStopY);
	  if (eval(iWordSelected) != -1 && abWordFound[eval(iWordSelected)] != "true") {{
	    abWordFound[eval(iWordSelected)] = "true";
	    HighlightSelection(iStartX, iStartY, iStopX, iStopY);
	    ComputeWordsLeft();
            UpdateWordsLeft();
	    DecrementTimeLeft(-20);
  	    PlaySound(document.bell);
	  } else {{
	    HintLetter(iStartX, iStartY, iStopX, iStopY, 0, "false", sSelectEndOld);
	    DecrementTimeLeft(5);
  	    PlaySound(document.buzzer);
	  } 

		  iPointsSelected = 0;
		  DisplayStatus(iPointsSelected);
		
		}

		function DecrementTimeLeft(iSeconds) {{

	  if (sGameState != "inplay")
	    return ("false");

	  iSecondsLeft = eval(eval(iSecondsLeft) - eval(iSeconds));

	  while (iSecondsLeft >= 60) {{
            iSecondsLeft -= 60;
            iMinutesLeft = eval(eval(iMinutesLeft) + 1);
          }

	  if (iSecondsLeft < 0) {{

	    iMinutesLeft = eval(eval(iMinutesLeft) - 1);

			if (iMinutesLeft < 0) {{
	    
			  iMinutesLeft = 0;
			  iSecondsLeft = 0;     
			  sGameState = "lost";
		          window.location="lose.tmpl";
			  return("false");
			  
			} else {{
	      
			  iSecondsLeft = eval(eval(iSecondsLeft) + 60);
	
			}

		  }

	  UpdateTimeLeft();
	      return("true");

		}

		function CallbackTimeLeft() {{
 
	  if (DecrementTimeLeft(5) == "true") {{  
		window.setTimeout("CallbackTimeLeft()", 5000);
	      } 

		}

	function GetDigit(iNumber, iDigit) {{

	  iNumber = "" + iNumber;  // Convert to "String" if it isn't already...

	  while (iNumber.length < 2) {{
	    iNumber = "0" + iNumber;
	  }

		  return(iNumber.charAt(iDigit));

		}

       
			

		function GetInCell(x, y) {{
	 
		  return (inpuzzle[y].substring(x, x+1));

	}

	function ComputeWordsLeft() {{

	  iWordsLeft = 0;
	  for (i=0; i < iTotalWords; i++) {{
	     if (abWordFound[eval(i)] == "false")
	       iWordsLeft++;
	  }

	  if (eval(iWordsLeft) == 0) {{
	    
	    sGameState = "won";
	    PlaySound(document.applause);
	    window.location="win.tmpl";
			
	  }

	}

	function UpdateWordsLeft() {{

	  if (eval(iWordsLeft) >= 10) {{
	    document.twords.src = "images/"+GetDigit(iWordsLeft, 0)+".gif";         
	      } else {{
		    document.twords.src = "/ROMCache/spacer.gif";
		  }
			   
	      document.owords.src = "images/"+GetDigit(iWordsLeft, 1)+".gif";         

	}

