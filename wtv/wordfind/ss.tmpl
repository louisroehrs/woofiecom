		  iStaryY = 0;  iStopY = 0;

		  sGameState = "inplay";                
		  iWordsLeft  = iTotalWords;
		  
		  abWordFound = new Array(iTotalWords);
		  for (i=0; i < iTotalWords; i++)
		     abWordFound[i] = "false";
		
