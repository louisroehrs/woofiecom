	function SetStart(x,y) {

		iStartX = x;

		iStartY = y;

	}

	

	function SetEnd(x,y) {

		iEndX = x;

		iEndY = y;

	}



	function Matched(x,y) {

		if ( puzzle[PuzzleLocation(x,y) ] == puzzle[PuzzleLocation(iStartX,iStartY) ] ) {

			return 1; 

		}

		else {

			return 0;

		}

	}

			

	function CallbackNoMatch() {

		iBlockClicks = 0;

		Cover(iStartX,iStartY);

		Cover(iEndX,iEndY);

	}

			

	function Cover(x,y) {

		

		document.images[PuzzleLocation(x,y) + kOtherFormElements ].src = "images/cover.gif";

	}

	

	function PuzzleLocation(x,y) {

		return eval (x + (y * kWidth));

	}

		

	function BuildPuzzle(kWidth, kHeight) {

	

		return true;

	}

	



	function PlaySound(sound) {



		if (sound == null) {  

            return;

		}

		else {

			sound.play(false);

		}

	}



	function SelectEndpoint(x,y) {



		if (sGameState != "inplay")

			return;



		if (iPointsSelected == 0) {

			iStartX = x; iStartY = y;

		    iPointsSelected = 1;

			DisplayStatus(iPointsSelected);

			HintLetter(x, y, x, y, 0, "true");

			return;

		}

	

		iStopX = x; iStopY = y;

	

		iWordSelected = CheckSelection(iStartX, iStartY, iStopX, iStopY);

		if (eval(iWordSelected) != -1 && abWordFound[eval(iWordSelected)] != "true") {

			abWordFound[eval(iWordSelected)] = "true";

			//if (debug) alert("iWordSelected: "+iWordSelected);

			HighlightSelection(iStartX, iStartY, iStopX, iStopY);

		 	ComputeWordsLeft();

	        UpdateWordsLeft();

		    DecrementTimeLeft(-20);

		}

		else {

			HintLetter(iStartX, iStartY, iStopX, iStopY, 0, "false");

			DecrementTimeLeft(5);

		} 

	

		iPointsSelected = 0;

		DisplayStatus(iPointsSelected);

		// if (debug) alert("After Status");

	   

	}



	function UpdateGameState(sGameState) {



//		document.gamestate.src=sGameState+".gif";

	}

	       

	function PuzzlePiece(x, y) {

		return (puzzle[PuzzleLocation(x,y)] );

	}



	function ComputeWordsLeft() {



		iWordsLeft = 0;

	  	for (i=0; i < iTotalWords; i++) {

			if (abWordFound[eval(i)] == "false")

				iWordsLeft++;

	  	}



		if (eval(iWordsLeft) == 0) {

		    sGameState = "won";

			UpdateGameState(sGameState);

			if (debug) alert("You Win!");

		}

	

	 // if (debug) alert("Exit Compute Words");



	}



	function LoadImages() {

		LoadClockImages();

	}



	<!-- Dynamic number utilities -->

	

	function GetDigit(iNumber, iDigit) {



		iNumber = "" + iNumber;  // Convert to "String" if it isn't already...



		while (iNumber.length < 2) {

			iNumber = "0" + iNumber;

		}

		return(iNumber.charAt(iDigit));

	}



	<!-- Countdown clock -->

	function DecrementTimeLeft(iSeconds) {



		if (sGameState != "inplay")

			return ("false");



		iSecondsLeft = eval(eval(iSecondsLeft) - eval(iSeconds));



		while (iSecondsLeft >= 60) {

			iSecondsLeft -= 60;

			iMinutesLeft = eval(eval(iMinutesLeft) + 1);

		}



		if (iSecondsLeft < 0) {



			iMinutesLeft = eval(eval(iMinutesLeft) - 1);



			if (iMinutesLeft < 0) {

	    

				// if (debug) alert("in here");

				iMinutesLeft = 0;

				iSecondsLeft = 0;     

				sGameState = "lost";

				UpdateGameState(sGameState);   

				PlaySound(document.explosion);	

				return("false");

			  

			}

			else {

	      

				iSecondsLeft = eval(eval(iSecondsLeft) + 60);

			}

		}



		UpdateTimeLeft();

		return("true");

	}



	function CallbackTimeLeft() {

 

		if (DecrementTimeLeft(5) == "true") {  

			window.setTimeout("CallbackTimeLeft()", 5000);

		} 

	}



	function GetDigit(iNumber, iDigit) {



		iNumber = "" + iNumber;  // Convert to "String" if it isn't already...



		while (iNumber.length < 2) {

			iNumber = "0" + iNumber;

		}

		return(iNumber.charAt(iDigit));

	}



	function LoadDigitImage(iDigit) {



	  var image = new Image();

	  image.src = "clock/" + iDigit+".gif";



	}  



	function LoadClockImages() {



		image0 = new Image();

		image0.src = "clock/0.gif";

		

		image1 = new Image();

		image1.src = "clock/1.gif";

		

		image2 = new Image();

		image2.src = "clock/2.gif";

		

		image3 = new Image();

		image3.src = "clock/3.gif";

		

		image4 = new Image();

		image4.src = "clock/4.gif";

		

		image5 = new Image();

		image5.src = "clock/5.gif";

		

		image6 = new Image();

		image6.src = "clock/6.gif";

		

		image7 = new Image();

		image7.src = "clock/7.gif";

		

		image8 = new Image();

		image8.src = "clock/8.gif";



		image9 = new Image();

		image9.src = "clock/9.gif";

	}



	function UpdateTimeLeft() {

		document.tenstime.src="clock/" + GetDigit(iSecondsLeft,0)+".gif";

		document.onestime.src="clock/" + GetDigit(iSecondsLeft,1)+".gif";

		document.minutes.src="clock/" + iMinutesLeft+".gif";

	}



	<!-- Specific Game board rendering -->

	

	function RenderTitle() {

		document.write("<font size='+5'>"+sGameTitle+"</font><BR>");

	}

	

	function RenderCell(x,y) {



		if (debug) alert("In Here");

//		gameboard[x][y] = new Cell("Cell"+x+"at"+y,"0",x,y)

//		var eval("Cell"+x+"at"+y) = new Cell("Cell"+x+"at"+y,"0",x,y)

		document.write("<td><a href='javascript:gameboard["+ x + "][" + y + "].select()'><img src='images/cover.gif' border=0 name='Cell"+x+"at"+y+"' width=50 height=50></a>");

		document.write("</td>");

		if (debug) alert("Out Here");  

	}

	

	<!-- Generic board rendering -->

	function RenderRow(y) {



		document.write("<tr>");



		for (x=0; x < kWidth; x++) {

			RenderCell(x,y);

		}

		document.write("</tr>");

	}



	function RenderPuzzle() {

		if (debug) alert("In Here!");

	 

		document.write("<table border=0 cellspacing=3 cellpadding=0 bgcolor=#222222>");



		for (y=0; y < kHeight; y++) {

			RenderRow(y);

		}

		document.write("</table>");

		return true;

	}



	<!-- Generic Game Functions -->

	function Restart() {

		location.reload();

	}



	function Quit() {

		if (debug) alert("Quit");

	}



	function SolvePuzzle() {



		for (i=0; i < iTotalWords; i++) {

		  

			// WebTV Javascript workaround 

			startx = eval(aStartX[i]);

			starty = eval(aStartY[i]);

			stopx  = eval(aStopX[i]);

			stopy  = eval(aStopY[i]);      

			  

			abWordFound[i] = "true";

			HighlightSelection(startx,starty,stopx,stopy);

		     

		}



		sGameState = "solved";

		iWordsLeft = 0;

		UpdateWordsLeft();

		UpdateGameState(sGameState);



	}



	function ShowHint() {



		// Find Answer to Hint



		if (sGameState != "inplay")

		return;



		for (iHintAnswer=0; 

			(abWordFound[eval(iHintAnswer)] != "false") && 

			(iHintAnswer < iTotalWords); 

			iHintAnswer++) { }



		if (iHintAnswer == iTotalWords)

			return;



		// Find Letter to Hint

		iHintLetter = Math.round(Math.random()*(

			eval(aLength[eval(iHintAnswer)])-1)

					  );

				     

		// Invert Letter



		//if (debug) alert("Hint Letter "+iHintLetter);



		HintLetter(aStartX[iHintAnswer], aStartY[iHintAnswer], 

			aStopX[iHintAnswer], aStopY[iHintAnswer], iHintLetter, "true");



		// Set Timer to Reinvert.

	  

		sCommand = "HintLetter("+aStartX[iHintAnswer]+","+aStartY[iHintAnswer]+","+aStopX[iHintAnswer]+","+aStopY[iHintAnswer]+","+iHintLetter+",\"false\")";

			window.setTimeout(sCommand, 500);



		DecrementTimeLeft(5);

		UpdateTimeLeft();

	

	}



	</script>

      





