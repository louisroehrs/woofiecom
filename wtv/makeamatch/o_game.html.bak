<title>MakeAMatch</title>



	<script language="JavaScript">

	

//  ************** Changable settings from HERE



	var sGameDir = "clock/"

	var asImageNames = new Array("0","1","2","3","4","5","6","7");

		

	var sGameTitle = "Numbers";



	var kWidth  = 5;

	var kHeight = 5;



	var iTotalWords = 8;

	var iMinutesLeft = 4;

	var iSecondsLeft = 15;



// *************** To HERE (Don't mess with the rest!);



// OBJECTS



function Cell(objName, contents, x,y)

{

  this.objName = objName

  this.contents = contents

  this.covered = true



  this.x = x

  this.y = y



  this.matched = false

// methods

  this.cover = Cover

  this.uncover = Uncover

  this.match = Matched



  this.select = SelectCell

}

	puzzle = new Array("0","2","4","6","4","7","3","6","0","7","5","5","2","1","1","3","8","9","8","9","0","0","0","0","0");



