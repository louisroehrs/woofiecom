		   woofie = puzzle[PuzzleLocation(i,j)]

	      gameboard[i][j] = new Cell(stuffy, woofie, i,j)

	   }

	}



	var iBlockClicks = 0;

	var debug=0;

	if (debug) alert("In Top!");



	 LoadImages();

	

	var iPointsSelected = 0;

	var iStartX = 0;  var iEndX = 0;

	var iStaryY = 0;  var iEndY = 0;

	

	var sGameState = "inplay";                

	  

	var kOtherFormElements = 6;



