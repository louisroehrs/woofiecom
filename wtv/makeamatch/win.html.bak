<html>
<head>
<title>WebTV MakeAMatch</title>
<bgsound src="sounds/kidstheme8.mid"> 
</head>

<SCRIPT Language="JavaScript">
	mam = new game("mam")
	
	function getURLvar(Name) {
		var search = Name + "="
		var incoming = window.location.search
		if (incoming.length > 0) { // if there are any search parameters
			offset = incoming.indexOf(search) 
			if (offset != -1) { // if parameter exists 
				offset += search.length 
				// set index of beginning of value
				end = incoming.indexOf("&", offset) 
				// set index of end of cookie value
				if (end == -1) 
					end = incoming.length
				value = unescape(incoming.substring(offset, end))
				if (value == "") {
					return null
				} else {
					return value
				}
			}
			else return null
		}
		else return null
	}
	
// GAME Object  new game(theme elements)
	function game(name) {
	
		this.name = name
		this.players = new Array ()
		this.addplayer = AddPlayer
		this.renderSidebar = RenderSidebar
		this.setup = SetupGame
		this.onePlayerScoreboard = OnePlayerScoreboard
		this.multiPlayerScoreboard = MultiPlayerScoreboard
		
		this.setup()		

	}
		
// GAME Methods

	function SetupGame() {  // called when GAME object constructed...

	// LOAD Players
		Aplayer = getURLvar ("player0")
		if ( Aplayer != null) {
			this.addplayer(Aplayer)
			this.players[0].score = getURLvar ("p0score")
		}
		else {
			this.addplayer("You")
			this.players[0].score = getURLvar ("p0score")
		}
		Aplayer = getURLvar ("player1")
		if (Aplayer != null) {
				this.addplayer(Aplayer)
				this.players[1].score = getURLvar ("p1score")

		}
		Aplayer = getURLvar ("player2")
		if ( Aplayer != null) {
				this.addplayer(Aplayer)
				this.players[2].score = getURLvar ("p2score")

		}
		
	}
			
	function AddPlayer(name) {
		qty =this.players.length
		this.players[qty] = new Player(name, qty)
	}

	function RenderSidebar() {
		document.write("<center>");
		if (this.players.length == 1) {

			this.onePlayerScoreboard() 
		}
		else {
			this.multiPlayerScoreboard()
		}
		document.write("</center>");

	}

	function OnePlayerScoreboard() {
	
		document.write("<br><img src=images/spacer.gif width=12 height=5><BR>");
		document.write("&nbsp;&nbsp;&nbsp;<FONT COLOR=996666 SIZE=+2><STRONG>");
		document.write(this.players[0].name + "</STRONG></FONT>&nbsp;&nbsp;&nbsp;");
		document.write("<FONT COLOR=996666 SIZE=+2><STRONG>");
		document.write(this.players[0].score);
		document.write("</STRONG></FONT><BR><BR>&nbsp;");
	}
	
	function MultiPlayerScoreboard() {
		document.write("<br><img src=images/spacer.gif width=12 height=5><BR>");
		document.write("<TABLE>");
		for (i=0; i< this.players.length; i++) {	
			document.write("<TR>");
			document.write("<TD align=right valign=top><FONT color=996666 SIZE=+3><STRONG>"+this.players[i].name + "</STRONG></FONT>&nbsp;&nbsp;&nbsp;</TD>");
			document.write("<TD align=left valign=top><FONT color=996666 SIZE=+3><STRONG>"+ this.players[i].score + " </STRONG></FONT><BR>&nbsp;</TD></TR>");
		}
			
		document.write("</TABLE>");
		document.write("<br><BR>");
	}	

// PLAYER Object

	function Player(name, id) {
		this.name = name
		this.score = 0
		this.id = id
	// methods
		this.addpoints = Paddpoint
		this.updatescore = Pupdatescore
	}

// PLAYER methods

	function Paddpoint(points) {
		this.score += points;
		this.updatescore()
	}

	function Pupdatescore() {
		document.scoreboard["player"+	this.id+"score"].value = this.score
	}

</SCRIPT>
<body valign=top hspace=0 bgcolor=#000000 text=#FFFFFF credits="http://www.woofie.com">


<table cellspacing=0 cellpadding=0 width=100%>
   
  <tr>
	<td colspan=2>
      <IMG src="images/spacer.gif" width=40 height=5>
    </td>
  </tr>

  <tr>
	<td colspan=2>
	  <center>
	    <img src="images/allstar.gif">
          </center>
        </td>
  </tr>
  
  <tr>
    <td>
      <center>
	<SCRIPT Language="JavaScript">
		mam.renderSidebar()
	</SCRIPT> </center>
	</td>
	<td><center>
	<a nocolor href="index.html">
          <img src="images/playagain.gif">
	</a><BR><BR><BR>

	<a nocolor href="wtv-home:/home.html">
          <img src="images/quit.gif">
	</a>
     
     </center>
    </td>
  </tr>

</table>
  
</html>
