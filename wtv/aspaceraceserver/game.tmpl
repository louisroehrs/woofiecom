	function Cell(objName, game, possible, position, contents, part, x,y, cellWidth, cellHeight)  {{ 
		if (objName == "")  {{ 
			objName = "Cell" + x + "at" + y
		}
		this.objName = objName
		this.possible = possible
		this.nexthop = null
		this.prevhop = null
		this.arrow = LoadImage("images/face" + contents +  ".gif");
		this.covered = 1
		this.game = game
		this.contents = contents
		this.part = LoadImage("images/part" + part + ".gif");
		this.parthigh = LoadImage("images/part" + part + "glow.gif"); 
		this.lightgreen = LoadImage("images/green.gif");
		this.lightred = LoadImage("images/red.gif");
		this.position = position
		this.x = x
		this.y = y
		this.cellWidth = cellWidth
		this.cellHeight = cellHeight
		this.matched = false
	// methods
		this.cover = Cover
		this.uncover = Uncover
		this.matches = Matches
		this.select = SelectCell
		this.render = RenderCell
		
		this.lastMove = LastMove
		this.unhighlight = UnhighlightLastMove
		this.properMove = ProperMove
	}




	function LastMove ()  {{ 

		var prev = this.game.previousCell
		if (prev != null)  {{  prev.unhighlight();}
		
		var lastmove = 1;
		var i=0
		if (this.contents == "u")  {{ 
			for (i=this.y; i>=0; i--)  {{ 
				if (this.game.board.cells[i][this.x].covered==1)  {{ 
					lastmove=0;
					document.images[this.game.board.cells[i][this.x].objName].src= this.game.board.cells[i][this.x].parthigh.src;
				}
			}
		}
		
		if ((this.contents == "d" ) && lastmove)  {{ 
			for (i=this.y; i< this.game.board.kHeight; i++)  {{ 
				if (this.game.board.cells[i][this.x].covered==1)  {{ 
					lastmove=0;
					document.images[this.game.board.cells[i][this.x].objName].src =this.game.board.cells[i][this.x].parthigh.src;

				}
			}
		}
		
		if ((this.contents == "l")  && lastmove)  {{ 
			for (i=this.x; i>=0; i--)  {{ 
				if (this.game.board.cells[this.y][i].covered==1)  {{ 
					lastmove=0;
					document.images[this.game.board.cells[this.y][i].objName].src =this.game.board.cells[this.y][i].parthigh.src;
				}
			}
		}
		
		if ((this.contents == "r")  && lastmove)  {{ 
			for (i=this.x; i<this.game.board.kWidth; i++)  {{ 
				if (this.game.board.cells[this.y][i].covered==1)  {{ 
					lastmove=0;
					document.images[this.game.board.cells[this.y][i].objName].src =this.game.board.cells[this.y][i].parthigh.src;
				}
			}
		}
			
		return lastmove;
	}
	
	function UnhighlightLastMove ()  {{ 
		var i=0

		var lastmove=1
		if (this.contents == "u")  {{ 
			for (i=this.y; i>=0; i--)  {{ 
				if (this.game.board.cells[i][this.x].covered==1)  {{ 
					lastmove=0;
					document.images[this.game.board.cells[i][this.x].objName].src= this.game.board.cells[i][this.x].part.src;
				}
			}
		}
		
		if ((this.contents == "d" )&& lastmove)  {{ 
			for (i=this.y; i< this.game.board.kHeight; i++)  {{ 
				if (this.game.board.cells[i][this.x].covered==1)  {{ 
					lastmove=0;
					document.images[this.game.board.cells[i][this.x].objName].src =this.game.board.cells[i][this.x].part.src;

				}
			}
		}
		
		if ((this.contents == "l" )&& lastmove)  {{ 
			for (i=this.x; i>=0; i--)  {{ 
				if (this.game.board.cells[this.y][i].covered==1)  {{ 
					lastmove=0;
					document.images[this.game.board.cells[this.y][i].objName].src =this.game.board.cells[this.y][i].part.src;
				}
			}
		}
		
		if ((this.contents == "r") && lastmove)  {{ 		
			for (i=this.x; i<this.game.board.kWidth; i++)  {{ 
				if (this.game.board.cells[this.y][i].covered==1)  {{ 
					lastmove=0;
					document.images[this.game.board.cells[this.y][i].objName].src =this.game.board.cells[this.y][i].part.src;
				}
			}
		}
			
	}


	function ProperMove ()  {{ 
	
		prev = this.game.previousCell
		
		if ((prev == null) && (this.x==0) && (this.y ==0)) return 1	  // Upper right square on first move is OK.
		if (prev == null) return 0   // Any other square on first move is not valid.
		
		if ((prev.contents == "u") && (this.y < prev.y) && (this.x==prev.x)) return 1
		if ((prev.contents == "d") && (this.y > prev.y) && (this.x==prev.x)) return 1
		if ((prev.contents == "l") && (this.x < prev.x) && (this.y==prev.y)) return 1
		if ((prev.contents == "r") && (this.x > prev.x) && (this.y==prev.y)) return 1
		
		return 0
	
	}
		
		
		
	function Uncover()  {{ 
		this.covered = 0;
		document.images[this.objName].src = this.arrow.src; 
		var ship = "s" + this.position;
		document.images[ship].src=this.lightgreen.src;

	}

	function Cover()  {{ 
		this.covered = 1
		document.images[this.objName].src = this.part.src
		var ship = "s" + this.position
		document.images[ship].src =this.lightred.src;

	}
	
	function RenderCell()  {{  
		document.write("<td background=images/qtrtoneflat.gif><a selected insetselection href='javascript:mam.board.cells["+ this.y + "][" + this.x + "].select();'><img src='images/spacer.gif' border=0 name='" + this.objName + "' width="+ this.cellWidth+" height=" + this.cellHeight + "></a>");
		document.write("</td>");
	}



	function SelectCell()  {{ 
		
		if (this.game.state != "inplay")
			return;

		window.status= "WebTV Space Race";
		if (!this.covered) 
			return;
			
		if (!this.properMove()) 
			return;
	
		this.uncover();

		if ((this.x == this.game.board.kWidth-1) && (this.y == this.game.board.kHeight-1))  {{ 
			if (this.game.board.cleared())  {{ 
				window.status = "You win!";
				this.game.win();
			}
			else  {{ 

				window.location = "http://ed.webtv.net/~tpark/new/spacerace/tryagain.zip";
			}
			return;
		}
		if (this.lastMove())  {{ 
			window.location = "http://ed.webtv.net/~tpark/new/spacerace/tryagain.zip";
		} 
		this.game.previousCell = this;
		return;
		
	}		

	
	
	function Matches(other)  {{ 
		return( this.contents == other.contents ) 
	}



	function game(name, kWidth, kHeight, cellWidth, cellHeight, iSecondsLeft)  {{ 
	
		this.name = name

		this.imageNames = asImageNames
		this.board = new gameboard(this, kWidth, kHeight, cellWidth, cellHeight)
		this.previousCell = null
		this.secondCell = null
		this.blockClicks = 0
		this.waitmatchflip = 1
		this.pointsSelected = 0;
		this.state = "inplay";
		this.BadMatchID = 0;
		this.needToCoverBadMatch= 0;
		this.matched = 0;
		this.messages = new Array("", "", "","");
		this.messageno = 0

		
		this.displaystatus = null
		this.start = StartGame
		this.coverunmatched = CallbackNoMatch
		this.win = Win
		this.nextMessage = NextMessage		
	}
		

	function NextMessage()  {{ 
		if (this.messageno >= this.messages.length)  {{  this.messageno=0}
		return this.messages[this.messageno++]
	}
		
	function Restart()  {{ 
		mam.board.clear();
		window.status="WebTV Space Race";
		document.images["Cell0at0"].src = mam.board.cells[0][0].parthigh.src;

	}
	
			
	function Win()  {{ 
		window.location = "http://ed.webtv.net/~tpark/new/spacerace/applause.mp2";
		wincommand = "flyout.tmpl";
		window.setTimeout(NextPage(),8000);
		window.location = "http://ed.webtv.net/~tpark/new/spacerace/applause.mp2";

	}

	function Lose()  {{ 
		mam.state = "lost";
		mam.blockClicks = 1;
		window.location = "dieonplanet.tmpl";
		
	}
	
	
	function NextPage()  {{ 
		window.location = wincommand;
	}

	function LoadImage(imageFileName)  {{ 
		
		newImage = new Image()
		newImage.src = imageFileName
		return newImage
				
	}

	
				
	function StartGame()  {{   // Called when game board is rendered.

		this.board.clear()
	}
	
	
