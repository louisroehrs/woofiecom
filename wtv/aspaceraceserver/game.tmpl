	function GameBoardCleared()  {{ 
		
		for (i=0; i < this.kHeight; i++)  {{ 
			for (j=0; j < this.kWidth; j++)  {{ 
				if (this.cells[i][j].covered) return 0
			}
		}
		return 1
	}
	
	function RenderGameBoard()  {{ 
		if (debug) alert("gameboard render");
		document.write("<table border=0  cellspacing=4 cellpadding=0>");
		
		for (i=0; i < this.kHeight; i++)  {{ 
			document.write("<tr>")
			if (i == 0)  {{ 
				document.write("<td rowspan=" + this.kHeight + " valign=top width=15 align=center><font size=-7>S<BR>T<BR>A<BR>R<BR>T</FONT></td>");
			}
			for (j=0; j < this.kWidth; j++)  {{ 
				this.cells[i][j].render()
			}
			
			if (i == 0)  {{ 
				document.write("<td valign=bottom rowspan=" + this.kHeight + "  width=15 align=center><font size=-7>F<BR>I<BR>N<BR>I<BR>S<BR>H</FONT></td>");
			}
			document.write("</tr>")
		}
		document.write("</table><BR>");
		if (debug) alert("gameboard done");
	}

	function ClearGameBoard()  {{ 
		for (i=0; i < this.kHeight; i++)  {{ 
			for (j=0; j < this.kWidth; j++)  {{ 
				this.cells[i][j].cover();
		   }
		}
		if (this.kHeight == 3)  {{ 
			var ship = "s0";
			for (i=10; i < 16; i++)  {{ 
				ship = "s" + i;
				document.images[ship].src="images/green.gif";
			}
		}

		this.game.previousCell = null;

	}
	
	function CallbackNoMatch()  {{ 
		if (this.needToCoverBadMatch ==1)  {{ 
		

			this.needToCoverBadMatch = 0;
			clearTimeout(this.BadMatchID)
			this.BadMatchTimeoutID = 0
			this.blockClicks = 0;
			this.firstCell.cover();
			this.secondCell.cover();
			this.nextPlayer();
		}
	}
	

	function GetDigit(iNumber, iDigit)  {{ 

		iNumber = "" + iNumber;  // Convert to "String" if it isn't already...

		while (iNumber.length < 2)  {{ 
			iNumber = "0" + iNumber;
		}
		return(iNumber.charAt(iDigit));
	}

	
	function Quit()  {{ 
		if (debug) alert("Quit");
	}

	function PlaySound(sound)  {{ 

		window.location=sound;
	}

	function splitString(mystring, delimiter)  {{ 
		var woofie = new Array()
		var index = 0;
		woofie[index] =""
		for (i=0; i<mystring.length; i++)  {{ 
			achar = mystring.charAt(i)
			if ( achar == delimiter)  {{ 
				index++
				woofie[index] =""
				}
			else
				woofie[index] += achar
		}

		return woofie
	}


	function getURLvar(Name)  {{ 
		var search = Name + "="
		var incoming = window.location.search
		if (incoming.length > 0)  {{ 
			offset = incoming.indexOf(search) 
			if (offset != -1)  {{ 
				offset += search.length 
		
				end = incoming.indexOf("&", offset) 
		
				if (end == -1) 
					end = incoming.length
				value = unescape(incoming.substring(offset, end))
				if (value == "")  {{ 
					return null
				} else  {{ 
					return value
				}
			}
			else return null
		}
		else return null
	}
	
	
	
