<html>
<head>
<title>Building game...</title>

<script language="JavaScript">

		status = "Building game..."
        kWidth  = 12;
        kHeight = 12;
        kOtherFormElements = 14;


		kTotalBombs = 0;
		kUncovered = 0;

        kDifficulty = getURLvar("diff");  // Probability of a space being a bomb.
		kLevelName = getURLvar("level");
		LoadImages();
  
		iLevelOn  = 1;
	  
		bUncovering = "true";        

		InitLevel();

 		userAgent=navigator.appName + " " + navigator.appVersion;
		
		kSafeSpaces = (kWidth * kHeight) - kTotalBombs;

	if (userAgent.indexOf("Plus") >0 ) {{
 		kBox = "Plus";
	} else {{  
		kBox = "FCS";
	}

	function UpdateTimeLeft() {{

		document.tenstime.src = "images/t"+GetDigit(iSecondsLeft,0)+".gif";
		document.onestime.src = "images/t"+GetDigit(iSecondsLeft,1)+".gif";
		document.minutes.src = "images/t"+iMinutesLeft+".gif";
	}

	function InitLevel() {{

		sGameState = "newlevel";
		kDifficulty = 1.1*kDifficulty;  // Probability of a space being a bomb.
		CreatePuzzle(); 
		CreateBombMap();
		iMinutesLeft = 5;
		iSecondsLeft = 00;
		sGameState="preplay";
	}

	function StartLevel() {{

		sGameState="inplay";
		window.setTimeout("CallbackTimeLeft()", 5000);
	}

	function CreateCell(x,y) {{
		if (Math.random() < kDifficulty) {{
 			return("b");
		} else {{
			return("-");
		}

	}

	function CreatePuzzle() {{

		var x = 0;
		var y = 0;

		puzzle = "";
		for (y=0; y < kHeight; y++) {{
			for (x=0; x < kWidth; x++) {{
				puzzle += CreateCell(x,y); 
			}
		}
	}

	function InBounds(x,y) {{

		if ((x < 0) || (x >= kWidth) || (y < 0) || (y >= kHeight)) {{
			
			return ("false");
		}
		return("true");
	}

	function TestCell(x,y) {{

		if (InBounds(x,y) == "false")
			return ("false");

		if (GetCell(x,y) == "b")
            return ("true"); 

		return("false");
	} 

	function HideMap() {{

		var x = 0;
		var y = 0;
		for (y=0; y < kHeight; y++) {{
			for (x=0; x < kWidth; x++) {{
				document.images[namexy(x,y)].src = "images/hidden.gif";
			}
		}

	}

 	function PlaySound(sound) {{

		if (sound == null) {{  
			return;
		} else {{
			sound.play(false);
		}
	}
	
	function CountAdjacentBombs(x,y) {{
         
	   var xm1 = 0;
	   var xp1 = 0;
	   var ym1 = 0;
	   var yp1 = 0;

	   var bombcount = 0;

	   xm1 = x-1;
	   xp1 = x+1;
	   ym1 = y-1;
	   yp1 = y+1;

	   if (TestCell(xm1, ym1) == "true") {{
			bombcount++;
	   }

	   if (TestCell(x,ym1) == "true")
             bombcount++;

		if (TestCell(xp1,ym1) == "true")
			bombcount++;

		if (TestCell(xp1,y) == "true")
			bombcount++;

		if (TestCell(xp1,yp1) == "true")
			bombcount++;

		if (TestCell(x,yp1) == "true")
			bombcount++;

		if (TestCell(xm1,yp1) == "true")
			bombcount++;

		if (TestCell(xm1,y) == "true")
			bombcount++;

		// alert("bombcount: " + x + "," + y + ": " + bombcount);
	   		   
	   return (bombcount);

	}

	function CreateBombMap() {{

		var x=0;
		var y=0;

		bombmap = "";

		for (y=0; y < kHeight; y++) {{
			for (x=0; x < kWidth; x++) {{

				if (GetCell(x,y) == "b") {{

					bombmap += "b";
					kTotalBombs += 1;
					
				} else {{
	
					bombmap = bombmap  + CountAdjacentBombs(x,y);
				}
             }
		}

	} 

	function CheckSelection(x,y) {{          

		if (GetCell(x,y) == "b")
             return("boom");
		else
             return("ok");	     
	}

	function SetCleared(x,y) {{
		if (IsCleared(x,y) == false) {{
		kUncovered += 1;
		}
	}

	function IsCleared(x,y) {{
		return(document.images[namexy(x,y)].src != "images/hidden.gif");
	}


	function namexy(x,y) {{
		return( x + "x" + y);
	}
		
    function RevealCell(x,y) {{
		SetCleared(x,y);
		document.images[namexy(x,y)].src = "images/"+GetBombMap(x,y)+".gif";

	}

	function FlagCell(x,y) {{

		if (IsCleared(x,y) == false) {{
		    var sCoverImage = document.images[namexy(x,y)].src; 
			if (sCoverImage == "images/hidden.gif") {{
				document.images[namexy(x,y)].src = "images/flagcell.gif";
            } else {{
				document.images[namexy(x,y)].src= "images/hidden.gif";
            }

		}

	}

	function GetCell(x,y) {{
		var start = x+y*kWidth
		var end = x+y*kWidth+1
		var stgg = puzzle.substring(start,end)
		return (stgg)
	}

	function GetBombMap(x, y) {{
  	   return (bombmap.substring(x+y*kWidth, x+y*kWidth+1));
	}


     function RevealMap(x,y) {{

		var x=0;
		var y=0;

		for (y=0; y < kHeight; y++) {{
			for (x=0; x < kWidth; x++) {{
				RevealCell(x,y);               
			}
		}

	}

	function HandleSelectArea (x,y) {{
		woofie = "select area " + x+ "x"+y;
		if (sGameState == "preplay") {{
			StartLevel();
		}
		SelectArea(x,y);
		
		if ((sGameState == "inplay") && (CheckForWin() == "t")) {{
			PlaySound(document.applause);
			window.setTimeout("window.location='win.tmpl';",5000)
		}
    }

	function Reveal9(x,y) {{
		
		xm1 = x-1;
		xp1 = x+1;
		ym1 = y-1;
		yp1 = y+1;

		if (InBounds(xm1, ym1) == "true") {{
				RevealCell(xm1, ym1);
		}

		if (InBounds(x,ym1) == "true") {{
				RevealCell(x, ym1);
		} 

		if (InBounds(xp1,ym1) == "true") {{
				RevealCell(xp1, ym1);
		}

		if (InBounds(xp1,y) == "true") {{
				RevealCell(xp1,y);
		}
			
		if (InBounds(xp1,yp1) == "true") {{
				RevealCell(xp1,yp1);
		}

		if (InBounds(x,yp1) == "true") {{
				RevealCell(x,yp1);
		}

		if (InBounds(xm1,yp1) == "true") {{
				RevealCell(xm1,yp1);
		}
		
		if (InBounds(xm1,y) == "true") {{
				RevealCell(xm1,y);
		}	
			
	}

     function SelectArea (x,y) {{
		//alert("selectarea");
		var xm1 = 0;
		var xp1 = 0;
		var ym1 = 0;
		var yp1 = 0;

		if (sGameState != "inplay")
			return;

		if ( IsCleared(x,y) == true) {{
			return;
		}

		RevealCell(x,y);

		if (GetCell(x,y) == "b") {{

			PlaySound(document.door);	
			RevealMap();
			sGameState = "lost";
		    return;
		} 

		if ((GetBombMap(x,y) != "0")) {{
			return;
		}
		
		if (kBox=="FCS") {{
			Reveal9(x,y);
			return;
		}
		
		xm1 = x-1;
		xp1 = x+1;
		ym1 = y-1;
		yp1 = y+1;

		if (InBounds(xm1, ym1) == "true") {{
			SelectArea(xm1, ym1);
		}

		if (InBounds(x,ym1) == "true") {{
			SelectArea(x, ym1);
		} 

		if (InBounds(xp1,ym1) == "true") {{
			SelectArea(xp1, ym1);
		}

		if (InBounds(xp1,y) == "true") {{
			SelectArea(xp1,y);
		}
			
		if (InBounds(xp1,yp1) == "true") {{
			SelectArea(xp1,yp1);
		}

		if (InBounds(x,yp1) == "true") {{
			SelectArea(x,yp1);
		}

		if (InBounds(xm1,yp1) == "true") {{
			SelectArea(xm1,yp1);
		}
		
		if (InBounds(xm1,y) == "true") {{
			SelectArea(xm1,y);
		}	
			
	}

	function CheckForWin() {{
		if (kSafeSpaces  == kUncovered) {{
			return("t");
		}
		return("f");
	}
	
	function SolvePuzzle() {{ 
		RevealMap();
	}
        
	function Restart() {{
		location.reload();
	}

	function DecrementTimeLeft(iSeconds) {{

		if (sGameState != "inplay") {{
			return ("false");
		}
		iSecondsLeft = iSecondsLeft- iSeconds;
		if (iSecondsLeft < 0) {{

			iMinutesLeft = iMinutesLeft - 1;

			if (iMinutesLeft < 0) {{
            
				iMinutesLeft = 0;
				iSecondsLeft = 0;	
				sGameState = "lost";
				window.location = "lose.tmpl";
 				RevealMap();
				PlaySound(document.door);
				return("false");
			} else {{
              
				iSecondsLeft = iSecondsLeft + 60;
        
			}

		}

		UpdateTimeLeft();
		return("true");

	}

	function CallbackTimeLeft() {{

 		if (DecrementTimeLeft(5) == "true") {{  
			window.setTimeout("CallbackTimeLeft()", 5000);
		} 

	}

	function LoadImages() {{

		image0 = new Image();
		image0.src = "images/t0.gif";

		image1 = new Image();
		image1.src = "images/t1.gif";

		image2 = new Image();
		image2.src = "images/t2.gif";

		image3 = new Image();
		image3.src = "images/t3.gif";

		image4 = new Image();
		image4.src = "images/t4.gif";

		image5 = new Image();
		image5.src = "images/t5.gif";

		image6 = new Image();
 		image6.src = "images/t6.gif";

		image7 = new Image();
		image7.src = "images/t7.gif";

		image8 = new Image();
		image8.src = "images/t8.gif";

		image9 = new Image();
		image9.src = "images/t9.gif";

		imagedetectoroff = new Image();
		imagedetectoroff.src = "images/switchsweep.jpg";

		imageflagon = new Image();
		imageflagon.src = "images/switchmark.jpg";

		imagequit = new Image();
		imagequit.src = "images/QUIT.GIF";
		  
		imagequit = new Image();
		imagequit.src = "images/b.gif";
		
		imagewaitover = new Image();
		imagewaitover.src = "images/waitoff.gif";
	

	}



	function GetDigit(iNumber, iDigit) {{

		iNumber = "" + iNumber;  // Convert to "String" if it isn't already...

		while (iNumber.length < 2) {{
			iNumber = "0" + iNumber;
		}
	
		return(iNumber.charAt(iDigit));

	}

	function RenderCell(x, y) {{ 
		bg = GetBombMap(x,y);
		if (bg=="b") {{ bg ="hiddenbg";  }
		document.write("<td abswidth=20 absheight=20 bgcolor=666666 align=center valign=bottom background=images/"+bg+".gif>");
		document.write("<a href='javascript:HandleSelectArea("+x+","+y+")'>");
		document.write("<img name=" + namexy(x,y) +" src=images/hidden.gif></a>");
		document.write("</td>");
	}

	function RenderRow(y) {{
		var x=0;
		document.write("<tr>");

		for (x=0; x < kWidth; x++) {{
			RenderCell(x,y);
		}

		document.write("</tr>");
	}

	function RenderPuzzle() {{
		var y=0;
		document.write("<table border=0 cellspacing=3 cellpadding=0 bgcolor=222222>");

		for (y=0; y < kHeight; y++) {{
			RenderRow(y);
		}
		document.write("</table>");
	}

	function SelectMode() {{

		if (bUncovering == "false") {{
			document.detector.src = "images/switchsweep.jpg";
			bUncovering = "true";
		} else {{
			document.detector.src = "images/switchmark.jpg";
			bUncovering = "false";
		}
	}

     function getURLvar(Name) {{

		var search = Name + "=";
		var incoming = window.location.search;
		if (incoming.length > 0) {{ 
			offset = incoming.indexOf(search) 
			if (offset != -1) {{ 
				offset += search.length;
				// set index of beginning of value
				end = incoming.indexOf("&", offset);
				// set index of end of cookie value
				if (end == -1) 
					end = incoming.length;
				value = unescape(incoming.substring(offset, end));
				if (value == "") {{
					return null;
				} else {{
					return value;
				}
			}
			else return null;
		}
		else return null;
	}

	</script>


</head>
