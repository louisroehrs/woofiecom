<html>

<title>WebTV MatchMate</title>
<head>
<script language="JavaScript">

function SetCookie (name, value)
{
   var argv = SetCookie.arguments;
   var argc = SetCookie.arguments.length;
   var expires = (argc > 2) ? argv[2] : null;
   var path = (argc > 3) ? argv[3] : null;
   var domain = (argc > 4) ? argv[4] : null;
   var secure = (argc > 5) ? argv[5] : false;
   document.cookie = name + "=" + escape (value) +
         ((expires == null) ? "" : ("; expires=" + expires.toGMTString())) +
         ((path == null) ? "" : ("; path=" + path)) +
         ((domain == null) ? "" : ("; domain=" + domain)) +
         ((secure == true) ? "; secure" : "");
}

function GetCookieVal (offset)
{
   var endstr = document.cookie.indexOf (";", offset);
   if (endstr == -1)
      endstr = document.cookie.length;
   return unescape(document.cookie.substring(offset, endstr));
}

function GetCookie (name)
{
   var arg = name + "=";
   var alen = arg.length;
   var clen = document.cookie.length;
   var i = 0;

   while (i < clen) {
      var j = i + alen;
      if (document.cookie.substring(i, j) == arg)
         return GetCookieVal (j);

      i = document.cookie.indexOf(" ", i) + 1;
      if (i == 0)
         break;
   }
   return null;
}

function AddToAccum (sCookieName, sPoints) {

  var expdate = new Date ();
  expdate.setTime (expdate.getTime() + (24 * 60 * 60 * 1000));

  var sAccum = GetCookie(sCookieName);

  if (sAccum == null) {
    sAccum = eval(sPoints);
  } else { 
    sAccum = eval(sAccum) + eval(sPoints); 
  }

  SetCookie (sCookieName, sAccum, expdate, "/");

}

function SetCookieMacro (sCookieName, sValue) {

  var expdate = new Date ();
  expdate.setTime (expdate.getTime() + (7 * 24 * 60 * 60 * 1000));

  SetCookie (sCookieName, sValue, expdate, "/");

}
// PLAYER NAME ENHANCEMENT

var prefix= new Array ("Amazing", "Buff", "Clever", "Daunting","Earnest","Frantic","Galloping","Hearty","Incredible","Jugular","Killer","Lunging","Muscle","Notable","Outstanding","Peppy","Quashing","Ruling","Scorching","Tactical","Ubiquitous","Voracious","Walloping","Yearning","Zealous");

function CleanString(dirty) {
	Clean = ""
	spacesok = 0
	for (i=0; i< dirty.length; i++) {  // Clean forward
		dirtychar = dirty.charAt(i)
		if  ( ( (dirtychar >= "a" ) && (dirtychar<="z") )  || ((dirtychar >= "A" ) && (dirtychar<="Z")) || ((dirtychar >= "0" ) && (dirtychar<="9"))) {
			Clean = Clean + dirtychar 
			spacesok =1 
		}
		else if ((dirtychar=" ") && spacesok) {  // Truncate leading spaces
				Clean = Clean + " "
			}
	}
	return Clean
}


function AddPrefix(playerName) {
	if (playerName != "") {
		playerName = CleanString (playerName)
		firstchar = playerName.substring(0,1)
		firstchar = firstchar.toUpperCase()
		for (i=0; i<prefix.length; i++) {
			if (prefix[i].charAt(0) == firstchar) {
				return (prefix[i] + "<BR>" + playerName)
			}
		}
		return "Number " + playerName
	} else {
		return ""
	}
}
	
	
function Redirect(sURL) {
  window.location=sURL;
} 

function GetSelection (thisControl) {
	return thisControl.options[thisControl.selectedIndex].text
}

function ToPage(pageName) {
//	rownum = GetSelection(document.form1.rows)
	rownum = 4
	colnum = 5
//	colnum = GetSelection(document.form1.cols)
	player0 =AddPrefix(document.form1.player0.value)
	player1 =AddPrefix(document.form1.player1.value)
	player2 =AddPrefix(document.form1.player2.value)

	location.href=pageName+"?rows="+ rownum + "&cols=" + colnum + "&player0=" + player0 + "&player1=" + player1 + "&player2=" + player2
}


</script>

