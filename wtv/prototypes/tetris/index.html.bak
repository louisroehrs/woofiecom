		Player 1&nbsp;<input type=text name=player0 size=10 maxlength=10 selected><br><br>	 
		Player 2&nbsp;<input type=text name=player1 size=10 maxlength=10><br><br>	 
		Player 3&nbsp;<input type=text name=player2 size=10 maxlength=10><br>	 
		</UL>
		 </tr>
	</td>
  </tr>

</table>
