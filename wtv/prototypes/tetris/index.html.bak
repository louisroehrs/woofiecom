					<CENTER><input type="button" name=action onClick="PassPlayersToGamePage()" value="PLAY"></CENTER>
				</td>
			</tr>
			<tr>
				<td align=left valign=top><BR><BR><BR><BR><BR><BR><BR><BR><BR><BR><BR><BR><HR><CENTER>Rows
				<select name="rows">
					<option value="4">4
					<option value="5" selected>5
					<option value="6" >6
					<option value="7">7
					<option value="8">8
				</select><BR>
				Cols&nbsp;
				<select name="cols" value="5">
					<option value="4">4
					<option value="5" selected>5
					<option value="6">6
					<option value="7">7
					<option value="8">8
				</select></CENTER>
				</td>
			</tr>	

		</table>

    </td>
	<td abswidth=20>
	</td>
	<td valign=top abswidth=320> <!-- instructions column -->
		<IMG width=10 height=30 src=images/spacer.gif><BR><BR>
		<CENTER><font color=#cccccc size=+2>Welcome to Make A Match</FONT></CENTER><BR>
		<BR><BR>
	
		One to three players can play Make-A-Match.
		Please enter the names of the players
		playing into the spaces below.  When you are done,
		click "Play" to go directly to Make-A-Match or
		"Rules" to learn how to play.<BR><BR>
