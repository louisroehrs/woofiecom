        createvrpdGrid: function(){
            var vrpdGrid = Ext.grid;
            // shorthand alias
            var fm = Ext.form, Ed = Ext.grid.GridEditor;
            
            // the column model has information about grid columns
            // dataIndex maps the column to the specific data field in
            // the data store (created below)
            var cm = new Ext.grid.ColumnModel([{
                header: "vRPD",
                dataIndex: 'vrpd',
                width: 50,
                editor: new Ed(new fm.NumberField({
                    allowBlank: false
                }))
            }, {
                header: "Frequency",
                dataIndex: 'frequency',
                width: 130,
                editor: new Ed(new Ext.form.ComboBox({
                    typeAhead: true,
                    triggerAction: 'all',
                    transform: 'light',
                    lazyRender: true
                }))
            }, {
                header: "Performance",
                dataIndex: 'performance',
                width: 70,
                align: 'right',
                renderer: 'usMoney',
                editor: new Ed(new fm.NumberField({
                    allowBlank: false,
                    allowNegative: false,
                    maxValue: 10
                }))
            }]);
            
            // by default columns are sortable
            cm.defaultSortable = true;
            
            // this could be inline, but we want to define the Plant record
            // type so we can add records dynamically
            var Channel = Ext.data.Record.create([ // the "name" below matches the tag name to read, except "availDate"
            // which is mapped to the tag "availability"
            {
                name: 'vrpd',
                type: 'int'
            }, {
                name: 'frequency',
                type: 'float'
            }, {
                name: 'performance',
                type: 'string'
            }]);
            
            // create the Data Store
            var ds = new Ext.data.Store({
                // load using HTTP
                proxy: new Ext.data.HttpProxy({
                    url: 'datagridtest.php'
                }),
                
                // the return will be XML, so lets set up a reader
                reader: new Ext.data.XmlReader({
                    // records will have a "plant" tag
                    record: 'channelizer'
                }, Channel)
            });
            
            // create the editor grid
            var grid = new Ext.grid.EditorGrid('editor-grid', {
                ds: ds,
                cm: cm,
                enableColLock: false
            });
            
            var layout = Ext.BorderLayout.create({
                center: {
                    margins: {
                        left: 3,
                        top: 3,
                        right: 3,
                        bottom: 3
                    },
                    panels: [new Ext.GridPanel(grid)]
                }
            }, 'grid-panel');
            
            
            // render it
            grid.render();
            
            
            var gridHead = grid.getView().getHeaderPanel(true);
            var tb = new Ext.Toolbar(gridHead, [{
                text: 'Save'
            }]);
            
            // trigger the data store load
            ds.load();
        },
